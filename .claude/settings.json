{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/learning-candidate.py\"",
            "timeout": 15,
            "statusMessage": "Checking for learning candidates…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__atlassian__createJiraIssue",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/log-jira-issue.py\"",
            "timeout": 5,
            "statusMessage": "Logging Jira issue…"
          }
        ]
      }
    ]
  }
}
