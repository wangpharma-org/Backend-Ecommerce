{
  "extraKnownMarketplaces": {
    "wangpharma": {
      "source": { "source": "github", "repo": "wangpharma-org/claude-plugins" }
    }
  },
  "enabledPlugins": {
    "vtsls-lsp@wangpharma": true
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/learning-candidate.py\"",
            "timeout": 15,
            "statusMessage": "Checking for learning candidates…"
          }
        ]
      }
    ]
  }
}
